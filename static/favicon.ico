<div class="picture">
<div class="img img-1" data-scroll="" data-scroll-speed="1.5"
data-scroll-position="top">
<div class="inner" data-lazy="/uploads/2023-01-09/48621939-9f1f-4f9c-bb52-d06693f8e7bd1673198765749.png"></div>
</div>
<div class="img img-2">
